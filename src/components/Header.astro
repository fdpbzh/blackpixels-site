---
const nav = [
  { href: '/', label: 'Accueil' },
  { href: '/about', label: 'À propos' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/prestations-tarifs', label: 'Prestations' },
  { href: '/avis', label: 'Avis' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
  { href: 'https://www.blackpixels.fr/clients', label: 'Espace client', external: true, button: true },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Black Pixels — Accueil">Black Pixels</a>
    <nav class="nav" aria-label="Navigation principale">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: current === item.href, 'nav-button': item.button }]}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(250, 248, 244, 0.92);
    backdrop-filter: blur(8px);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }
  .nav { display: flex; gap: 2rem; flex-wrap: wrap; }
  .nav-link {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
  }
  .nav-link.active { border-bottom-color: var(--color-accent); }
  .nav-link:hover { color: var(--color-accent-dark); }

  /* Espace client : style bouton doré */
  .nav-link.nav-button {
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    padding: 0.45rem 0.9rem;
    color: var(--color-accent-dark);
    transition: background 0.2s, color 0.2s;
  }
  .nav-link.nav-button:hover {
    background: var(--color-accent);
    color: white;
  }
  .nav-link.nav-button.active {
    border-bottom-color: var(--color-accent);
  }
  @media (max-width: 768px) {
    .header-inner { flex-direction: column; gap: 1rem; }
    .nav { gap: 1rem; justify-content: center; }
    .nav-link { font-size: 0.75rem; }
  }
</style>
