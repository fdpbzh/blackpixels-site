---
import LanguageSwitcher from './LanguageSwitcher.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

// Détecte la langue courante
let currentLocale = 'fr';
if (pathname.startsWith('/en')) currentLocale = 'en';
else if (pathname.startsWith('/es')) currentLocale = 'es';

// Labels et liens selon la langue
const navByLocale = {
  fr: [
    { href: '/', label: 'Accueil' },
    { href: '/about', label: 'À propos' },
    { href: '/portfolio', label: 'Portfolio' },
    { href: '/prestations-tarifs', label: 'Prestations' },
    { href: '/avis', label: 'Avis' },
    { href: '/faq', label: 'FAQ' },
    { href: '/contact', label: 'Contact' },
  ],
  en: [
    { href: '/en', label: 'Home' },
    { href: '/en/about', label: 'About' },
    { href: '/en/portfolio', label: 'Portfolio' },
    { href: '/en/prestations-tarifs', label: 'Packages' },
    { href: '/en/avis', label: 'Reviews' },
    { href: '/en/faq', label: 'FAQ' },
    { href: '/en/contact', label: 'Contact' },
  ],
  es: [
    { href: '/es', label: 'Inicio' },
    { href: '/es/about', label: 'Sobre mí' },
    { href: '/es/portfolio', label: 'Portafolio' },
    { href: '/es/prestations-tarifs', label: 'Tarifas' },
    { href: '/es/avis', label: 'Opiniones' },
    { href: '/es/faq', label: 'FAQ' },
    { href: '/es/contact', label: 'Contacto' },
  ],
};

const clientSpaceLabel = {
  fr: 'Espace client',
  en: 'Client area',
  es: 'Área cliente',
};

const homeAriaLabel = {
  fr: 'Black Pixels · Accueil',
  en: 'Black Pixels · Home',
  es: 'Black Pixels · Inicio',
};

const nav = navByLocale[currentLocale];
const current = pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href={currentLocale === 'fr' ? '/' : `/${currentLocale}`} class="logo" aria-label={homeAriaLabel[currentLocale]}>Black Pixels</a>
    <nav class="nav" aria-label="Navigation">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: current === item.href || (item.href !== '/' && item.href !== '/en' && item.href !== '/es' && current.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://www.blackpixels.fr/clients"
        class="nav-link nav-button"
        target="_blank"
        rel="noopener"
      >
        {clientSpaceLabel[currentLocale]}
      </a>
    </nav>
    <div class="lang-zone">
      <LanguageSwitcher />
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(250, 248, 244, 0.92);
    backdrop-filter: blur(8px);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }
  .nav { display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center; }
  .nav-link {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
  }
  .nav-link.active { border-bottom-color: var(--color-accent); }
  .nav-link:hover { color: var(--color-accent-dark); }

  /* Espace client : style bouton doré */
  .nav-link.nav-button {
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    padding: 0.45rem 0.9rem;
    color: var(--color-accent-dark);
    transition: background 0.2s, color 0.2s;
  }
  .nav-link.nav-button:hover {
    background: var(--color-accent);
    color: white;
  }
  .nav-link.nav-button.active {
    border-bottom-color: var(--color-accent);
  }

  .lang-zone {
    padding-left: 1rem;
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 900px) {
    .header-inner { flex-direction: column; gap: 1rem; }
    .nav { gap: 1rem; justify-content: center; }
    .nav-link { font-size: 0.75rem; }
    .lang-zone { padding-left: 0; border-left: none; }
  }
</style>
