---
const year = new Date().getFullYear();

const pathname = Astro.url.pathname;
let currentLocale = 'fr';
if (pathname.startsWith('/en')) currentLocale = 'en';
else if (pathname.startsWith('/es')) currentLocale = 'es';

const t = {
  fr: {
    tagline1: 'Photographe mariage en Bretagne depuis 2017.',
    tagline2: 'Wedding Awards 2021, 2022, 2026.',
    contact: 'Contact',
    address: ['Pors Poulhan', '29780 Plouhinec', 'Bretagne, France'],
    links: 'Liens',
    prestations: 'Prestations & Tarifs',
    faq: 'FAQ',
    avis: 'Avis clients',
    portfolio: 'Portfolio',
    clientArea: 'Espace client',
    copyright: 'Tous droits réservés',
  },
  en: {
    tagline1: 'Wedding photographer in Brittany since 2017.',
    tagline2: 'Wedding Awards 2021, 2022, 2026.',
    contact: 'Contact',
    address: ['Pors Poulhan', '29780 Plouhinec', 'Brittany, France'],
    links: 'Links',
    prestations: 'Packages & Pricing',
    faq: 'FAQ',
    avis: 'Reviews',
    portfolio: 'Portfolio',
    clientArea: 'Client area',
    copyright: 'All rights reserved',
  },
  es: {
    tagline1: 'Fotógrafo de bodas en Bretaña desde 2017.',
    tagline2: 'Wedding Awards 2021, 2022, 2026.',
    contact: 'Contacto',
    address: ['Pors Poulhan', '29780 Plouhinec', 'Bretaña, Francia'],
    links: 'Enlaces',
    prestations: 'Paquetes y tarifas',
    faq: 'FAQ',
    avis: 'Opiniones',
    portfolio: 'Portafolio',
    clientArea: 'Área cliente',
    copyright: 'Todos los derechos reservados',
  },
};

const labels = t[currentLocale];
const prefix = currentLocale === 'fr' ? '' : `/${currentLocale}`;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <h4 class="footer-title">Black Pixels</h4>
      <p class="text-muted">{labels.tagline1}</p>
      <p class="text-muted">{labels.tagline2}</p>
    </div>

    <div class="footer-col">
      <h4 class="footer-title">{labels.contact}</h4>
      <p><a href="mailto:blackpixels.fr@gmail.com">blackpixels.fr@gmail.com</a></p>
      <p><a href="tel:+33687708908">+33 6 87 70 89 08</a></p>
      <p class="text-muted">{labels.address[0]}<br />{labels.address[1]}<br />{labels.address[2]}</p>
    </div>

    <div class="footer-col">
      <h4 class="footer-title">{labels.links}</h4>
      <p><a href={`${prefix}/prestations-tarifs`}>{labels.prestations}</a></p>
      <p><a href={`${prefix}/faq`}>{labels.faq}</a></p>
      <p><a href={`${prefix}/avis`}>{labels.avis}</a></p>
      <p><a href={`${prefix}/portfolio`}>{labels.portfolio}</a></p>
      <p><a href="https://www.blackpixels.fr/clients" target="_blank" rel="noopener">{labels.clientArea}</a></p>
    </div>
  </div>

  <div class="footer-bottom container">
    <p class="text-muted">© {year} Black Pixels · {labels.copyright}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 1.5rem;
    margin-top: 4rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
  .footer-col p { font-size: 0.9rem; margin-bottom: 0.4rem; }
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    text-align: center;
  }
  .footer-bottom p { font-size: 0.8rem; margin: 0; }
</style>
