---
import BaseLayout from '../layouts/BaseLayout.astro';
import reviewsData from '../data/reviews.json';

const title = 'Avis · Ce que disent les couples qui m\'ont fait confiance';
const description = `Découvrez les avis vérifiés des couples qui ont fait appel à Black Pixels pour leur mariage. ${reviewsData.totalReviews} avis sur Mariages.net, note moyenne ${reviewsData.aggregateRating}/5, ${reviewsData.recommendationRate}% de recommandation.`;

// Format date en français
function formatDate(iso) {
  const months = ['janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'];
  const [y, m, d] = iso.split('-');
  return `${parseInt(d, 10)} ${months[parseInt(m, 10) - 1]} ${y}`;
}

// Schema.org JSON-LD pour les rich snippets Google
const schemaReviews = reviewsData.reviews.map((r) => ({
  '@type': 'Review',
  author: { '@type': 'Person', name: r.author },
  datePublished: r.date,
  reviewBody: r.body,
  name: r.title,
  reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
}));

const fullSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://www.blackpixels.fr/#localbusiness',
  name: 'Black Pixels',
  image: 'https://www.blackpixels.fr/og-default.jpg',
  url: 'https://www.blackpixels.fr',
  review: schemaReviews,
};
---

<BaseLayout title={title} description={description}>
  <section class="avis-hero">
    <div class="container-narrow text-center">
      <p class="eyebrow">Avis vérifiés</p>
      <h1>Ce que disent les couples<br />qui m'ont fait confiance.</h1>
      <div class="rating-summary">
        <span class="stars" aria-label={`Note ${reviewsData.aggregateRating} sur 5`}>★★★★★</span>
        <span class="rating-value">{reviewsData.aggregateRating.toFixed(1)}</span>
        <span class="rating-meta">
          {reviewsData.totalReviews} avis · {reviewsData.recommendationRate}% recommandent
        </span>
      </div>
      <p class="source">
        Tous les avis ci-dessous sont <strong>vérifiés sur Mariages.net</strong>, ils ont été publiés par les couples eux-mêmes.
      </p>
    </div>
  </section>

  <section class="reviews-list">
    <div class="container-narrow">
      {reviewsData.reviews.map((r) => (
        <article class="review-card">
          <header class="review-head">
            <div>
              <p class="review-author">{r.author}</p>
              <p class="review-date">{formatDate(r.date)}</p>
            </div>
            <span class="review-stars" aria-label="5 étoiles sur 5">★★★★★</span>
          </header>
          {r.title && <h2 class="review-title">{r.title}</h2>}
          <blockquote class="review-body">{r.body}</blockquote>
          <p class="review-source-link">
            <a href={reviewsData.sourceUrl} target="_blank" rel="noopener nofollow">
              Avis vérifié sur Mariages.net ↗
            </a>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-more">
    <div class="container-narrow text-center">
      <p class="eyebrow">Vous voulez en lire plus ?</p>
      <h2>{reviewsData.totalReviews - reviewsData.extractedReviews} autres avis vous attendent</h2>
      <p class="text-muted">L'intégralité des {reviewsData.totalReviews} avis est consultable sur Mariages.net.</p>
      <p style="margin-top: 2rem;">
        <a href={reviewsData.sourceUrl} target="_blank" rel="noopener" class="button">
          Voir les {reviewsData.totalReviews} avis sur Mariages.net
        </a>
      </p>
    </div>
  </section>

  <section class="cta-final-avis">
    <div class="container-narrow text-center">
      <p class="eyebrow">Convaincus ?</p>
      <h2>Parlons de votre mariage</h2>
      <p>Devis personnalisé sous 48h.</p>
      <p style="margin-top: 1.5rem;">
        <a href="/contact" class="button">Demander un devis</a>
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(fullSchema)} />
</BaseLayout>

<style>
  .avis-hero {
    padding: 5rem 0 3rem;
  }
  .rating-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin: 1.5rem 0 1rem;
    font-size: 1.1rem;
  }
  .rating-summary .stars {
    color: var(--color-accent);
    font-size: 1.4rem;
    letter-spacing: 0.05em;
  }
  .rating-summary .rating-value {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    color: var(--color-text);
  }
  .rating-summary .rating-meta {
    color: var(--color-text-muted);
  }
  .source {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: 1.5rem;
  }

  .reviews-list { padding-top: 2rem; }
  .review-card {
    background: white;
    border: 1px solid var(--color-border);
    padding: 2rem;
    margin-bottom: 1.5rem;
  }
  .review-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }
  .review-author {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin: 0;
    color: var(--color-text);
  }
  .review-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0.2rem 0 0;
  }
  .review-stars {
    color: var(--color-accent);
    font-size: 1rem;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .review-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    margin: 0.5rem 0 1rem;
    line-height: 1.3;
  }
  .review-body {
    margin: 0;
    padding: 0 0 0 1rem;
    border-left: 2px solid var(--color-accent);
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.7;
    font-style: normal;
  }
  .review-body::before, .review-body::after { content: none; }
  .review-source-link {
    margin-top: 1.25rem;
    font-size: 0.8rem;
  }
  .review-source-link a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .review-source-link a:hover {
    color: var(--color-accent-dark);
  }

  .cta-more { background: white; }
  .cta-final-avis { padding-bottom: 6rem; }
</style>
