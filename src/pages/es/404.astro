      <p class="eyebrow">Error 404</p>
      <h1>Esta página se fue de luna de miel</h1>
      <p class="text-muted">Quizás vuelva algún día. Mientras tanto:</p>
      <p style="margin-top: 2rem;">
        <a href="/es" class="button">Volver al inicio</a>
      </p>
    </div>
  </section>
</BaseLayout>
