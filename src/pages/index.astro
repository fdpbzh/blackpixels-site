---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Photographe Mariage Bretagne';
const description = 'Photographe mariage haut de gamme en Bretagne (Finistère, Morbihan, Côtes-d\'Armor). Reportage cinématographique, au naturel. Wedding Awards 2021, 2022, 2026.';
---

<BaseLayout title={title} description={description}>
  <section class="hero-full">
    <img src="/images/hero.jpg" alt="Mariage en Bretagne, ambiance cinématographique au naturel" width="2400" height="1350" />
    <div class="hero-overlay">
      <p class="hero-eyebrow">Photographe de mariage · Bretagne</p>
      <h1>Vos émotions, au naturel.</h1>
      <p class="hero-sub">Vos instants volés, un regard de cinéma sur votre journée.</p>
    </div>
  </section>

  <section class="humain">
    <div class="container humain-grid">
      <div class="humain-photo">
        <img src="/images/yohann.jpg" alt="Yohann Strullu, photographe de mariage en Bretagne" width="2048" height="1152" />
      </div>
      <div class="humain-text">
        <p class="eyebrow">Le regard</p>
        <h2>L'œil cinéma derrière l'objectif.</h2>
        <p>
          Je m'appelle Yohann. J'ai appris à photographier face à la mer, là où tout se joue
          à l'observation et au timing : chaque seconde est unique, et ne revient pas.
          Un mariage, c'est exactement ça.
        </p>
        <p>
          Je commence par créer un lien avec vous, pour que vous restiez vous-mêmes.
          Puis je m'efface, et je capte ces instants avec un œil de cinéma.
        </p>
        <p>
          <a href="/about">Découvrir mon parcours →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="regard">
    <div class="container text-center">
      <p class="eyebrow">Le portfolio</p>
      <h2>Peu de poses, beaucoup d'instants volés.</h2>
      <p class="text-muted regard-intro">
        Un reportage vivant, fidèle à ce que vous vivez vraiment.
      </p>
    </div>
    <div class="strip-grid">
      <img src="/images/band-1.jpg" alt="Baiser des mariés sous une arche, en noir et blanc" width="1600" height="900" />
      <img src="/images/band-2.jpg" alt="Silhouettes au coucher de soleil pendant le dîner" width="1600" height="900" />
      <img src="/images/band-3.jpg" alt="Couple devant un château en Bretagne, en noir et blanc" width="1600" height="900" />
      <img src="/images/band-4.jpg" alt="Première danse, jeux de lumière" width="1600" height="900" />
    </div>
    <div class="container text-center">
      <a href="/portfolio" class="button button-outline">Voir le portfolio</a>
    </div>
  </section>

  <section class="lieux">
    <div class="container lieux-grid">
      <div class="lieux-text">
        <p class="eyebrow">Lieux de mariage</p>
        <h2>Bretagne, et au-delà sur demande.</h2>
        <p>
          <strong>Ferme du Roudouic</strong>, <strong>Château de Keriolet</strong>,
          <strong>Manoir de Kerhuel</strong>, <strong>Orangerie de Lanniron</strong>,
          <strong>Manoir des Indes</strong>… j'ai mes habitudes dans plein de lieux du Finistère
          et autour. Déplacement inclus partout en Bretagne. Disponible également pour la
          France, ou le monde, faites-moi rêver !
        </p>
      </div>
      <div class="lieux-photo">
        <img src="/images/portfolio-014.jpg" alt="Arrivée de la mariée en hélicoptère devant un lieu de réception, en noir et blanc" width="801" height="1200" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="temoignage">
    <div class="container-narrow text-center">
      <p class="quote">« Vous ne le voyez quasiment pas, il fond dans le décor… mais il a l'œil pour capturer tous les moments clés. »</p>
      <p class="quote-author">Frances &amp; Alexandre</p>
      <p class="trust-line text-muted">5/5 · 61 avis sur Mariages.net · Wedding Awards 2021 · 2022 · 2026</p>
      <p><a href="/avis">Lire tous les avis →</a></p>
    </div>
  </section>

  <section class="cta-final">
    <div class="cta-bg">
      <img src="/images/photo-016.jpg" alt="Feuille de discours posée dans l'herbe" width="580" height="326" />
    </div>
    <div class="container-narrow text-center cta-content">
      <p class="eyebrow">On commence ?</p>
      <h2>On en parle quand vous voulez.</h2>
      <p>
        Envoyez-moi un message avec votre date, votre lieu, et ce que vous avez en tête.
        Je vous réponds sous 48h, et si vous voulez on peut prendre un café pour discuter de tout ça.
      </p>
      <p style="margin-top: 1.5rem;">
        <a href="/contact" class="button">Envoyer un message</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO PLEIN ECRAN : format cinema 2.35 */
  .hero-full {
    position: relative;
    padding: 0;
    aspect-ratio: 2.35 / 1;
    overflow: hidden;
  }
  .hero-full > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    background: rgba(26, 26, 26, 0.28);
    color: var(--color-bg);
  }
  .hero-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(250, 248, 244, 0.9);
  }
  .hero-overlay h1 {
    color: var(--color-bg);
    margin: 0 0 1rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    max-width: 36rem;
    color: rgba(250, 248, 244, 0.9);
    margin: 0;
  }

  /* L'HUMAIN */
  .humain { background: white; }
  .humain-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    align-items: center;
  }
  .humain-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }
  .humain h2 { margin-bottom: 1.5rem; }

  /* LE REGARD */
  .regard-intro {
    max-width: 36rem;
    margin: 0 auto;
    font-size: 1.1rem;
  }
  .strip-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0;
    margin: 3rem 0;
  }
  .strip-grid img {
    width: 100%;
    aspect-ratio: 2.35 / 1;
    object-fit: cover;
    display: block;
  }

  /* LIEUX */
  .lieux-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: center;
  }
  .lieux-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }

  /* TÉMOIGNAGE */
  .temoignage { background: white; }
  .quote {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 0 0 1rem;
  }
  .quote-author {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
  .trust-line {
    font-size: 0.85rem;
    margin: 0 0 1.5rem;
  }

  /* CTA FINAL */
  .cta-final {
    position: relative;
    padding: 8rem 0;
    overflow: hidden;
  }
  .cta-bg { position: absolute; inset: 0; z-index: 0; }
  .cta-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4);
  }
  .cta-content { position: relative; z-index: 1; color: var(--color-bg); }
  .cta-content h2 { color: var(--color-bg); }
  .cta-content .eyebrow { color: var(--color-accent); }
  .cta-content p { color: rgba(250, 248, 244, 0.85); }
  .cta-content .button {
    background: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-bg);
  }
  .cta-content .button:hover {
    background: transparent;
    color: var(--color-bg);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .humain-grid, .lieux-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .strip-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .hero-full { aspect-ratio: auto; }
    .hero-full > img { position: static; width: 100%; height: auto; aspect-ratio: 16 / 9; }
    .hero-overlay {
      position: static;
      height: auto;
      background: transparent;
      color: var(--color-text);
      padding: 2.5rem 1.5rem 1rem;
    }
    .hero-eyebrow { color: var(--color-accent-dark); }
    .hero-overlay h1 { color: var(--color-text); }
    .hero-sub { color: var(--color-text-muted); }
    .strip-grid { grid-template-columns: 1fr; }
    .strip-grid img { aspect-ratio: 16 / 9; }
  }
