---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Exemple de reportage · Mariage complet en Bretagne';
const description = 'Un reportage de mariage complet en Bretagne, du début à la fin. 115 photos pour vous montrer concrètement ce que vous recevez après votre journée.';

// 115 photos : reportage-001 à reportage-115
const photos = Array.from({ length: 115 }, (_, i) => {
  const n = String(i + 1).padStart(3, '0');
  return { n, alt: `Reportage mariage Bretagne, photo ${i + 1}` };
});
---

<BaseLayout title={title} description={description}>
  <section class="reportage-hero">
    <div class="container-narrow text-center">
      <p class="eyebrow">Un mariage en exemple</p>
      <h1>Un reportage de mariage complet</h1>
      <p class="lead text-muted">
        115 photos d'un mariage, du début à la fin. Pour vous montrer concrètement
        ce que vous recevez après votre journée, sans sélection arrangée.
      </p>
    </div>
  </section>

  <section class="reportage-grid-section">
    <div class="reportage-container">
      <div class="masonry">
        {photos.map((p, i) => (
          <button
            type="button"
            class="photo-btn"
            data-index={i}
            data-src={`/images/reportage/reportage-${p.n}.jpg`}
            aria-label={`Voir la photo : ${p.alt}`}
          >
            <img
              src={`/images/reportage/reportage-${p.n}.jpg`}
              alt={p.alt}
              loading="lazy"
              width="800"
              height="600"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="reportage-cta">
    <div class="container-narrow text-center">
      <p class="eyebrow">Convaincu ?</p>
      <h2>Parlons de votre mariage</h2>
      <p>Devis personnalisé sous 48h.</p>
      <p style="margin-top: 2rem;">
        <a href="/contact" class="button">Demander un devis</a>
        <a href="/portfolio" class="button button-outline">Voir le portfolio</a>
      </p>
    </div>
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="Fermer">×</button>
    <button class="lightbox-prev" aria-label="Photo précédente">‹</button>
    <img class="lightbox-img" src="" alt="" />
    <button class="lightbox-next" aria-label="Photo suivante">›</button>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = lightbox.querySelector('.lightbox-img');
    const closeBtn = lightbox.querySelector('.lightbox-close');
    const prevBtn = lightbox.querySelector('.lightbox-prev');
    const nextBtn = lightbox.querySelector('.lightbox-next');
    const buttons = Array.from(document.querySelectorAll('.photo-btn'));
    let currentIndex = 0;
    function open(idx) {
      currentIndex = idx;
      lightboxImg.src = buttons[idx].dataset.src;
      lightboxImg.alt = buttons[idx].querySelector('img').alt;
      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    function next() { open((currentIndex + 1) % buttons.length); }
    function prev() { open((currentIndex - 1 + buttons.length) % buttons.length); }
    buttons.forEach((btn, idx) => btn.addEventListener('click', () => open(idx)));
    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowRight') next();
      if (e.key === 'ArrowLeft') prev();
    });
  });
</script>

<style>
  .reportage-hero { padding: 4rem 0 3rem; }
  .lead { font-size: 1.1rem; margin-top: 1rem; }
  .reportage-container { max-width: 1400px; margin: 0 auto; padding: 0 1rem; }
  .masonry { column-count: 3; column-gap: 1rem; }
  @media (max-width: 900px) { .masonry { column-count: 2; } }
  @media (max-width: 500px) { .masonry { column-count: 1; } }
  .photo-btn {
    width: 100%; padding: 0; margin: 0 0 1rem;
    border: none; background: none; cursor: pointer;
    break-inside: avoid; display: block; overflow: hidden;
  }
  .photo-btn img { width: 100%; height: auto; display: block; transition: opacity 0.3s, transform 0.5s; }
  .photo-btn:hover img { opacity: 0.85; transform: scale(1.02); }
  .reportage-cta { padding: 4rem 0; background: white; }
  .reportage-cta p { margin-bottom: 1.5rem; }
  .reportage-cta .button { margin: 0 0.5rem; }
  .lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.95); display: none; align-items: center; justify-content: center; z-index: 1000; }
  .lightbox.open { display: flex; }
  .lightbox-img { max-width: 92%; max-height: 92%; object-fit: contain; display: block; }
  .lightbox button { background: rgba(255,255,255,0.1); color: white; border: none; cursor: pointer; font-size: 2rem; position: absolute; transition: background 0.2s; }
  .lightbox button:hover { background: rgba(255,255,255,0.2); }
  .lightbox-close { top: 1.5rem; right: 1.5rem; width: 48px; height: 48px; }
  .lightbox-prev, .lightbox-next { top: 50%; transform: translateY(-50%); width: 56px; height: 56px; }
  .lightbox-prev { left: 1.5rem; }
  .lightbox-next { right: 1.5rem; }
</style>
