---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable" description="Cette page n'existe pas ou plus.">
  <section class="text-center">
    <div class="container-narrow">
      <p class="eyebrow">Erreur 404</p>
      <h1>Cette page est partie en lune de miel</h1>
      <p class="text-muted">Elle reviendra peut-être un jour. En attendant :</p>
      <p style="margin-top: 2rem;">
        <a href="/" class="button">Retour à l'accueil</a>
      </p>
    </div>
  </section>
</BaseLayout>
