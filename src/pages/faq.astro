---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'FAQ — Questions fréquentes';
const description = 'Vos questions sur mes prestations photo de mariage en Bretagne : tarifs, livraison, méthode, lieux, matériel. Réponses claires et directes.';

const faqs = [
  {
    q: "C'est quoi vos tarifs ?",
    a: "3 packs : Pack White à 1 490 €, Pack Black à 2 390 €, Pack Gold à 3 290 €. Le détail complet est sur la page Prestations & Tarifs.",
  },
  {
    q: "Sous quel délai je reçois mes photos ?",
    a: "2 semaines maxi après votre mariage. Toutes en couleur ET en noir & blanc, retouchées sous Lightroom.",
  },
  {
    q: "Comment je réserve une date ?",
    a: "Vous me demandez un devis via le formulaire de contact. Je réponds sous 48h, et si vous voulez on prend un café ou un appel pour faire connaissance avant de bloquer la date.",
  },
  {
    q: "Combien de mariages couvrez-vous par an ?",
    a: "Une vingtaine, pas plus. Au-delà, je ne peux plus garantir le niveau d'attention que chaque mariage mérite — rencontre en amont, présence intégrale le jour J, retouche soignée et livraison rapide. Je préfère faire moins, et faire bien.",
  },
  {
    q: "Comment ça se passe pour le paiement ?",
    a: "30 % d'acompte à la réservation (qui bloque votre date), le solde le jour J. Virement, espèces ou chèque, comme vous préférez.",
  },
  {
    q: "Vous intervenez dans toute la Bretagne ?",
    a: "Oui — Finistère, Morbihan, Côtes-d'Armor, Ille-et-Vilaine. Déplacement inclus partout en Bretagne. Hors Bretagne, faites-moi rêver, on en parle.",
  },
  {
    q: "Combien de photos je reçois ?",
    a: "Selon le pack : 300 (White), 500 (Black), 700 (Gold). Toutes retouchées, livrées en haute définition.",
  },
  {
    q: "C'est quoi votre approche ?",
    a: "Reportage authentique. J'aime prendre mon temps, observer, varier les angles et les cadres, et capter ce que vous ressentez vraiment — pas ce que vous montrez. Je me fais discret pour laisser place au naturel.",
  },
  {
    q: "On peut personnaliser un pack ?",
    a: "Bien sûr. Vous pouvez ajouter Save the Date (400 €), Préparation (400 €), Soirée (500 €), Trash the Dress (400 €) ou Retour de Noce (500 €) à n'importe quel pack.",
  },
  {
    q: "Vous avez des récompenses ?",
    a: "Wedding Awards Mariages.net en 2021, 2022 et 2026. Ce sont les couples qui votent. 100 % de mes 61 clients me recommandent.",
  },
  {
    q: "Dans quels lieux vous travaillez le plus ?",
    a: "J'ai mes habitudes à la Ferme du Roudouic, au Château de Keriolet, au Manoir de Kerhuel, à l'Orangerie de Lanniron et au Manoir des Indes. Mais je m'adapte partout en Bretagne.",
  },
  {
    q: "Vous travaillez seul ou en équipe ?",
    a: "Seul. Je suis présent du début à la fin, c'est ma promesse. Pas de second photographe qui ferait moitié des photos pendant que je suis ailleurs.",
  },
  {
    q: "Et s'il y a un imprévu ?",
    a: "J'ai des photographes de confiance en backup pour les cas vraiment exceptionnels (accident, maladie grave). Mais en 8 ans, je n'ai jamais loupé un mariage.",
  },
  {
    q: "Vous pouvez rester plus longtemps si besoin ?",
    a: "Oui — heures supplémentaires à 150 €/heure. À décider sur le moment si la fête bat son plein.",
  },
  {
    q: "Quel matériel vous utilisez ?",
    a: "Nikon Z9 avec des optiques fixes : 50 mm f/1.2, 24 mm f/1.4, 105 mm f/1.4. Pour les puristes : du matériel pro avec double boîtier en backup. Pour les autres : ça fait des belles photos.",
  },
  {
    q: "Comment je récupère mes photos ?",
    a: "Galerie en ligne sécurisée et privée. Vous et vos invités pouvez télécharger les photos en haute définition. Pratique pour partager.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description}>
  <section>
    <div class="container-narrow">
      <p class="eyebrow text-center">FAQ</p>
      <h1 class="text-center">Vos questions, mes réponses</h1>

      <div class="faqs">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <p class="text-center" style="margin-top: 3rem;">
        Une autre question ? <a href="/contact">Écrivez-moi</a>.
      </p>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </section>
</BaseLayout>

<style>
  .faqs { margin-top: 3rem; }
  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .faq-item summary {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    cursor: pointer;
    list-style: none;
    padding: 0.5rem 0;
    position: relative;
    padding-right: 2rem;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: var(--color-accent-dark);
    transition: transform 0.2s;
  }
  .faq-item[open] summary::after {
    content: '−';
  }
  .faq-item p {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
  }
</style>
