---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="This page doesn't exist or no longer exists.">
  <section class="text-center">
    <div class="container-narrow">
      <p class="eyebrow">Error 404</p>
      <h1>This page is off on a honeymoon</h1>
      <p class="text-muted">It might come back one day. In the meantime:</p>
      <p style="margin-top: 2rem;">
        <a href="/en" class="button">Back to home</a>
      </p>
    </div>
  </section>
</BaseLayout>
