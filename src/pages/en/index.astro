---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Wedding Photographer in Brittany, France';
const description = 'Yohann Strullu, high-end wedding photographer based in Brittany (Finistère, Morbihan, Côtes-d\'Armor). Documentary approach, cinematic eye. Wedding Awards 2021, 2022, 2026.';
---

<BaseLayout title={title} description={description}>
  <section class="hero-full">
    <img src="/images/hero.jpg" alt="Wedding in Brittany, natural cinematic mood" width="2400" height="1350" />
    <div class="hero-overlay">
      <p class="hero-eyebrow">Wedding photographer · Brittany</p>
      <h1 lang="fr">Vos émotions, au naturel.</h1>
      <p class="hero-sub">Your stolen moments, a cinematic eye on your wedding day.</p>
    </div>
  </section>

  <section class="humain">
    <div class="container humain-grid">
      <div class="humain-photo">
        <img src="/images/yohann.jpg" alt="Yohann Strullu, wedding photographer in Brittany" width="2048" height="1152" />
      </div>
      <div class="humain-text">
        <p class="eyebrow">The eye</p>
        <h2>A cinematic eye behind the lens.</h2>
        <p>
          My name is Yohann. I learned photography facing the sea, where it all comes down
          to observation and timing: every second is unique, and never comes back.
          A wedding is exactly that.
        </p>
        <p>
          I start by building a connection with you, so you can stay yourselves. Then I step
          back, and I capture those moments with a cinematic eye.
        </p>
        <p>
          <a href="/en/about">Read my story →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="regard">
    <div class="container text-center">
      <p class="eyebrow">Portfolio</p>
      <h2>Few poses, many stolen moments.</h2>
      <p class="text-muted regard-intro">
        A living documentary, true to what you actually experience.
      </p>
    </div>
    <div class="strip-grid">
      <img src="/images/band-1.jpg" alt="Newlyweds kissing under an arch, in black and white" width="1600" height="900" />
      <img src="/images/band-2.jpg" alt="Silhouettes at sunset during dinner" width="1600" height="900" />
      <img src="/images/band-3.jpg" alt="Couple in front of a château in Brittany, in black and white" width="1600" height="900" />
      <img src="/images/band-4.jpg" alt="First dance, lighting effects" width="1600" height="900" />
    </div>
    <div class="container text-center">
      <a href="/en/portfolio" class="button button-outline">View the portfolio</a>
    </div>
  </section>

  <section class="lieux">
    <div class="container lieux-grid">
      <div class="lieux-text">
        <p class="eyebrow">Wedding venues</p>
        <h2>Brittany, and beyond on request.</h2>
        <p>
          <strong>Ferme du Roudouic</strong>, <strong>Château de Keriolet</strong>,
          <strong>Manoir de Kerhuel</strong>, <strong>Orangerie de Lanniron</strong>,
          <strong>Manoir des Indes</strong>… I have my habits in many venues across Finistère
          and nearby. Travel within Brittany is included. Available for France and worldwide
          weddings too. Surprise me, let's talk.
        </p>
      </div>
      <div class="lieux-photo">
        <img src="/images/portfolio-014.jpg" alt="Bride arriving by helicopter at a wedding venue, in black and white" width="801" height="1200" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="temoignage">
    <div class="container-narrow text-center">
      <p class="quote">“You barely notice him, he blends into the background… yet he has the eye to capture every key moment.”</p>
      <p class="quote-author">Frances &amp; Alexandre</p>
      <p class="trust-line text-muted">5/5 · 61 reviews · 100% recommendation · Wedding Awards 2021 · 2022 · 2026</p>
      <p><a href="/en/avis">Read all reviews →</a></p>
    </div>
  </section>

  <section class="cta-final">
    <div class="cta-bg">
      <img src="/images/photo-016.jpg" alt="A sheet of paper lying in the grass" width="580" height="326" />
    </div>
    <div class="container-narrow text-center cta-content">
      <p class="eyebrow">Shall we start?</p>
      <h2>Let's talk whenever you're ready.</h2>
      <p>
        Send me a message with your date, your venue, and what you have in mind.
        I reply within 48 hours, and if you'd like we can grab a coffee to talk it through.
      </p>
      <p style="margin-top: 1.5rem;">
        <a href="/en/contact" class="button">Send a message</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO : cinematic 2.35 full-width */
  .hero-full {
    position: relative;
    padding: 0;
    aspect-ratio: 2.35 / 1;
    overflow: hidden;
  }
  .hero-full > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    background: rgba(26, 26, 26, 0.28);
    color: var(--color-bg);
  }
  .hero-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(250, 248, 244, 0.9);
  }
  .hero-overlay h1 { color: var(--color-bg); margin: 0 0 1rem; }
  .hero-sub {
    font-size: 1.1rem;
    max-width: 36rem;
    color: rgba(250, 248, 244, 0.9);
    margin: 0;
  }

  /* WHO I AM */
  .humain { background: white; }
  .humain-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    align-items: center;
  }
  .humain-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }
  .humain h2 { margin-bottom: 1.5rem; }

  /* THE EYE */
  .regard-intro { max-width: 36rem; margin: 0 auto; font-size: 1.1rem; }
  .strip-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0;
    margin: 3rem 0;
  }
  .strip-grid img {
    width: 100%;
    aspect-ratio: 2.35 / 1;
    object-fit: cover;
    display: block;
  }

  /* VENUES */
  .lieux-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: center;
  }
  .lieux-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }

  /* TESTIMONIAL */
  .temoignage { background: white; }
  .quote {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 0 0 1rem;
  }
  .quote-author { font-size: 0.95rem; color: var(--color-text-muted); margin: 0 0 1.5rem; }
  .trust-line { font-size: 0.85rem; margin: 0 0 1.5rem; }

  /* CTA FINAL */
  .cta-final { position: relative; padding: 8rem 0; overflow: hidden; }
  .cta-bg { position: absolute; inset: 0; z-index: 0; }
  .cta-bg img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.4); }
  .cta-content { position: relative; z-index: 1; color: var(--color-bg); }
  .cta-content h2 { color: var(--color-bg); }
  .cta-content .eyebrow { color: var(--color-accent); }
  .cta-content p { color: rgba(250, 248, 244, 0.85); }
  .cta-content .button {
    background: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-bg);
  }
  .cta-content .button:hover { background: transparent; color: var(--color-bg); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .humain-grid, .lieux-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .strip-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .hero-full { aspect-ratio: auto; }
    .hero-full > img { position: static; width: 100%; height: auto; aspect-ratio: 16 / 9; }
    .hero-overlay {
      position: static;
      height: auto;
      background: transparent;
      color: var(--color-text);
      padding: 2.5rem 1.5rem 1rem;
    }
    .hero-eyebrow { color: var(--color-accent-dark); }
    .hero-overlay h1 { color: var(--color-text); }
    .hero-sub { color: var(--color-text-muted); }
    .strip-grid { grid-template-columns: 1fr; }
    .strip-grid img { aspect-ratio: 16 / 9; }
  }
