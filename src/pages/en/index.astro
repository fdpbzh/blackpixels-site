---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Wedding Photographer in Brittany, France';
const description = 'Yohann Strullu, high-end wedding photographer based in Brittany (Finistère, Morbihan, Côtes-d\'Armor). Documentary approach, cinematic eye. Wedding Awards 2021, 2022, 2026.';
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">Wedding photographer · Brittany</p>
        <h1 lang="fr">Au naturel.</h1>
        <p class="hero-tagline text-muted">
          Yohann Strullu, <strong>high-end wedding photographer</strong> in Brittany, France.
          Documentary approach, cinematic eye.
        </p>
        <div class="trust-bar">
          <span class="stars" aria-label="Rating 5 out of 5">★★★★★</span>
          <span class="trust-rating">5.0</span>
          <span class="trust-sep">·</span>
          <span><strong>61 reviews</strong>, 100% recommendation rate</span>
          <span class="trust-sep">·</span>
          <span>Wedding Awards <strong>2021 · 2022 · 2026</strong></span>
          <a href="/en/avis" class="trust-link">Read the reviews →</a>
        </div>
        <div class="hero-cta">
          <a href="/en/prestations-tarifs" class="button">View packages</a>
          <a href="/en/contact" class="button button-outline">Get a quote</a>
        </div>
      </div>
      <div class="hero-photo">
        <img src="/images/photo-001.jpg" alt="First dance at Ferme du Roudouic, wedding in Brittany" width="580" height="326" />
        <p class="photo-caption">First dance, Ferme du Roudouic</p>
      </div>
    </div>
  </section>

  <section class="intro">
    <div class="container intro-grid">
      <div class="intro-photo">
        <img src="/images/yohann.jpg" alt="Yohann Strullu at Cinéma Eckmühl, signing session" width="2048" height="1152" />
      </div>
      <div class="intro-text">
        <p class="eyebrow">Black Pixels</p>
        <h2>A filmmaker's eye behind the lens.</h2>
        <p>
          Yohann Strullu, wedding photographer in Brittany. My background in documentary
          filmmaking shapes every wedding I cover.
        </p>
        <p>
          <a href="/en/about">Read my story →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="gallery-strip">
    <div class="strip-grid">
      <img src="/images/photo-068.jpg" alt="Outdoor ceremony at Ferme du Roudouic" width="580" height="326" />
      <img src="/images/photo-005.jpg" alt="Orangerie de Lanniron lit up at night" width="580" height="326" />
      <img src="/images/photo-073.jpg" alt="Bride and groom leaving the town hall" width="580" height="326" />
      <img src="/images/photo-067.jpg" alt="Detail of the bride's hairstyle" width="580" height="326" />
    </div>
  </section>

  <section class="packs-preview">
    <div class="container text-center">
      <p class="eyebrow">Packages</p>
      <h2>Three formats, one same commitment</h2>
      <div class="packs-grid">
        <article class="pack-card pack-theme-white">
          <h3>White</h3>
          <p class="pack-price">€1,500</p>
          <p class="pack-desc">Ceremony + Cocktail + Group photos + Couple session.<br />300 photos.</p>
        </article>
        <article class="pack-card pack-theme-black pack-featured">
          <p class="pack-badge">Most chosen</p>
          <h3>Black</h3>
          <p class="pack-price">€2,400</p>
          <p class="pack-desc">Everything in White + Getting ready + Reception.<br />500 photos.</p>
        </article>
        <article class="pack-card pack-theme-gold">
          <h3>Gold</h3>
          <p class="pack-price">€3,300</p>
          <p class="pack-desc">Everything in Black + 2h Couple session + 3h Day-after shoot.<br />700 photos.</p>
        </article>
      </div>
      <p style="margin-top: 2rem;">
        <a href="/en/prestations-tarifs" class="button button-outline">See full packages</a>
      </p>
    </div>
  </section>

  <section class="lieux">
    <div class="container lieux-grid">
      <div class="lieux-text">
        <p class="eyebrow">Wedding venues</p>
        <h2>Brittany, and beyond on request.</h2>
        <p>
          <strong>Ferme du Roudouic</strong>, <strong>Château de Keriolet</strong>,
          <strong>Manoir de Kerhuel</strong>, <strong>Orangerie de Lanniron</strong>,
          <strong>Manoir des Indes</strong>… I have my habits in many venues across Finistère
          and nearby. Travel within Brittany is included. Available for France and worldwide
          weddings too. Surprise me, let's talk.
        </p>
      </div>
      <div class="lieux-photo">
        <img src="/images/photo-078.jpg" alt="Couple session at Ferme du Roudouic" width="580" height="326" />
      </div>
    </div>
  </section>

  <section class="cta-final">
    <div class="cta-bg">
      <img src="/images/photo-016.jpg" alt="A sheet of paper lying in the grass" width="580" height="326" />
    </div>
    <div class="container-narrow text-center cta-content">
      <p class="eyebrow">Shall we start?</p>
      <h2>Let's talk whenever you're ready.</h2>
      <p>
        Send me a message with your date, your venue, and what you have in mind.
        I reply within 48 hours, and if you'd like we can grab a coffee to talk it through.
      </p>
      <p style="margin-top: 1.5rem;">
        <a href="/en/contact" class="button">Send a message</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { padding: 5rem 0 4rem; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero h1 { margin-bottom: 1.5rem; line-height: 1.1; }
  .hero-tagline { font-size: 1.15rem; margin-bottom: 1.5rem; }
  .trust-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin-bottom: 2rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }
  .trust-bar .stars {
    color: var(--color-accent);
    letter-spacing: 0.05em;
    font-size: 0.95rem;
  }
  .trust-bar .trust-rating {
    font-weight: 600;
    color: var(--color-text);
  }
  .trust-bar .trust-sep {
    color: var(--color-border);
  }
  .trust-bar strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .trust-bar .trust-link {
    margin-left: auto;
    color: var(--color-accent-dark);
    font-weight: 500;
    white-space: nowrap;
    text-decoration: none;
    transition: color 0.2s;
  }
  .trust-bar .trust-link:hover {
    color: var(--color-text);
  }
  @media (max-width: 600px) {
    .trust-bar .trust-link { margin-left: 0; }
  }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }
  .photo-caption {
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.75rem;
  }

  /* INTRO */
  .intro { padding: 6rem 0; background: white; }
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .intro-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }
  .intro h2 { margin-bottom: 1.5rem; }

  /* GALLERY STRIP */
  .gallery-strip { padding: 0; }
  .strip-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0;
  }
  .strip-grid img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
  }

  /* PACKS */
  .packs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .pack-card {
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-border);
    text-align: center;
    position: relative;
    transition: transform 0.2s;
  }
  .pack-card:hover { transform: translateY(-4px); }
  .pack-badge {
    position: absolute;
    top: -0.7rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: white;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    margin: 0;
  }
  .pack-price {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin: 1rem 0;
  }
  .pack-desc { font-size: 0.95rem; opacity: 0.8; }

  .pack-theme-white {
    background: white;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .pack-theme-white .pack-price { color: var(--color-accent-dark); }

  .pack-theme-black {
    background: #1A1A1A;
    color: #F0EBE0;
    border-color: #1A1A1A;
  }
  .pack-theme-black .pack-price { color: var(--color-accent); }
  .pack-theme-black .pack-desc { color: rgba(240, 235, 224, 0.75); opacity: 1; }

  .pack-theme-gold {
    background: var(--color-accent);
    color: #1A1A1A;
    border-color: var(--color-accent);
  }
  .pack-theme-gold .pack-price { color: #1A1A1A; }
  .pack-theme-gold .pack-desc { color: rgba(26, 26, 26, 0.8); opacity: 1; }

  /* LIEUX */
  .lieux-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .lieux-photo img {
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(26, 26, 26, 0.15);
  }

  /* CTA FINAL */
  .cta-final {
    position: relative;
    padding: 8rem 0;
    overflow: hidden;
    border-top: none;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .cta-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4);
  }
  .cta-content {
    position: relative;
    z-index: 1;
    color: var(--color-bg);
  }
  .cta-content h2 { color: var(--color-bg); }
  .cta-content .eyebrow { color: var(--color-accent); }
  .cta-content p { color: rgba(250, 248, 244, 0.85); }
  .cta-content .button {
    background: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-bg);
  }
  .cta-content .button:hover {
    background: transparent;
    color: var(--color-bg);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-grid, .intro-grid, .lieux-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .strip-grid {
      grid-template-columns: 1fr 1fr;
    }
    .strip-grid img { height: 220px; }
  }
  @media (max-width: 500px) {
    .strip-grid { grid-template-columns: 1fr; }
  }
</style>
