---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Contact · Wedding photography quote Brittany';
const description = 'Send me your date and venue, I reply within 48h. Black Pixels, wedding photographer in Brittany.';
---

<BaseLayout title={title} description={description}>
  <section>
    <div class="container-narrow">
      <p class="eyebrow text-center">Contact</p>
      <h1 class="text-center">Shall we talk?</h1>
      <p class="text-center text-muted lead">
        Send me your date, your venue, and what you have in mind. I reply within 48 hours.
      </p>

      <div class="contact-grid">
        <div class="contact-info">
          <h3>My contact details</h3>
          <p><strong>Email</strong><br /><a href="mailto:blackpixels.fr@gmail.com">blackpixels.fr@gmail.com</a></p>
          <p><strong>Phone</strong><br /><a href="tel:+33687708908">+33 6 87 70 89 08</a></p>
          <p><strong>Address</strong><br />Pors Poulhan, Bâtiment les Cotiers<br />29780 Plouhinec, Brittany, France</p>
        </div>

        <form
          class="contact-form"
          action="https://formspree.io/f/xgoqvgbg"
          method="POST"
        >
          <label>
            Your name
            <input type="text" name="name" required />
          </label>
          <label>
            Email
            <input type="email" name="email" required />
          </label>
          <label>
            Wedding date (if known)
            <input type="date" name="wedding_date" />
          </label>
          <label>
            Venue (if planned)
            <input type="text" name="location" placeholder="Ferme du Roudouic, Manoir de Kerhuel…" />
          </label>
          <label>
            Package of interest
            <select name="pack">
              <option value="">Pick one</option>
              <option value="white">White (€1,500)</option>
              <option value="black">Black (€2,400)</option>
              <option value="gold">Gold (€3,300)</option>
              <option value="autre">Custom</option>
            </select>
          </label>
          <label>
            Your message
            <textarea name="message" rows="5" required placeholder="A few words about your wedding, what you have in mind, what matters to you…"></textarea>
          </label>
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_subject" value="New quote request · Black Pixels" />
          <button type="submit" class="button">Send my request</button>
          <p class="form-note text-muted">
            Your data is only used to reply to your request. No mailing list, no resale.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lead { font-size: 1.15rem; margin-bottom: 3rem; }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-top: 2rem;
  }
  .contact-info h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }
  .contact-info p {
    font-size: 0.95rem;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: white;
    padding: 2.5rem;
    border: 1px solid var(--color-border);
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    gap: 0.5rem;
    font-weight: 500;
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text);
    text-transform: none;
    letter-spacing: normal;
    font-weight: 400;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .contact-form button {
    margin-top: 1rem;
    align-self: flex-start;
  }
  .form-note {
    font-size: 0.8rem;
    margin: 0;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .contact-form { padding: 1.5rem; }
  }
</style>
